# FastAPI Configuration
HOST=127.0.0.1
PORT=8000
SECRET_KEY=generate-a-strong-random-key-here-for-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440
ENVIRONMENT=development

# LLM Configuration
# LLM_PROVIDER can be auto, groq, or openai. auto prefers Groq if both keys exist.
LLM_PROVIDER=auto
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile
OPENAI_API_KEY=your_openai_api_key_here
LLM_MODEL=gpt-4o-mini

# Langfuse Configuration (Observability)
# Leave blank to disable Langfuse monitoring
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# File storage config
UPLOAD_DIR=data/resumes
JD_DIR=data/job_descriptions
DATABASE_FILE=data/database.json
